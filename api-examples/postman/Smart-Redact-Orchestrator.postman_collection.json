							"raw": "{\n    \"name\": \"My Detection Config\",\n    \"description\": \"Custom detection configuration\",\n    \"isDefault\": false,\n    \"configuration\": {\n        \"scoreThreshold\": 0.5,\n        \"labels\": [\"EMAIL_ADDRESS\", \"PHONE_NUMBER\", \"CREDIT_CARD\", \"IBAN\"],\n        \"languages\": [\"en\", \"de\"]\n    }\n}"
