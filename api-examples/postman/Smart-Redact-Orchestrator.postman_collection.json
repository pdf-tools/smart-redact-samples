							"raw": "{{baseUrl}}/v1/detection-configurations",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"v1",
								"detection-configurations"
							]
						},
						"description": "Creates a detection configuration with all available options including pattern recognizers, keyword recognizers, keyword exclusions, semantic recognizer, and same-span strategy."
