						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Full Detection Config\",\n    \"description\": \"Detection configuration with all options\",\n    \"isDefault\": false,\n    \"configuration\": {\n        \"scoreThreshold\": 0.5,\n        \"labels\": [\n            \"ALPHANUMERIC_CODE\",\n            \"BARCODE\",\n            \"BIC_SWIFT\",\n            \"CREDIT_CARD\",\n            \"CURRENCY_CODE\",\n            \"DATE\",\n            \"DATETIME\",\n            \"DECIMAL_NUMBER\",\n            \"DOMAIN_NAME\",\n            \"DURATION\",\n            \"EMAIL_ADDRESS\",\n            \"FILE_PATH\",\n            \"GPS_COORDINATE\",\n            \"HASHTAG\",\n            \"HTTP_COOKIE\",\n            \"IBAN\",\n            \"INTEGER_NUMBER\",\n            \"IP_ADDRESS\",\n            \"ISIN\",\n            \"KEYWORD\",\n            \"LEI\",\n            \"MAC_ADDRESS\",\n            \"MENTION\",\n            \"MONEY\",\n            \"NUMERIC_ID\",\n            \"ORGANISATION\",\n            \"PERCENTAGE\",\n            \"PERSON\",\n            \"PHONE_NUMBER\",\n            \"PHYSICAL_ADDRESS\",\n            \"SCIENTIFIC_NUMBER\",\n            \"SSN\",\n            \"TIME\",\n            \"UNIQUE_IDENTIFIER\",\n            \"URL\",\n            \"USERNAME\",\n            \"VAT_NUMBER\",\n            \"VIN\"],\n        \"languages\": [\"en\", \"de\"],\n        \"regexTimeout\": 1000,\n        \"patternRecognizers\": [\n            {\n                \"name\": \"UsSsnRecognizer\",\n                \"label\": \"SSN\",\n                \"patterns\": [\n                    {\n                        \"name\": \"UsSSN\",\n                        \"regex\": \"\\\\b\\\\d{3}-\\\\d{2}-\\\\d{4}\\\\b\",\n                        \"score\": 0.85,\n                        \"allowBacktracking\": false\n                    }\n                ],\n                \"contextWords\": [\"SSN\", \"Sozialversicherungsnummer\", \"Versicherungsnummer\", \"Identifikationsnummer\"]\n            }\n        ],\n        \"keywordRecognizers\": [\n            {\n                \"name\": \"MyCustomDenyKeywords\",\n                \"label\": \"KEYWORD\",\n                \"keywords\": [\"Deutsche Nationalbank\"],\n                \"partialMatch\": false\n            }\n        ],\n        \"keywordExclusions\": [\n            {\n                \"name\": \"MyCustomSafeKeywords\",\n                \"excludedKeywords\": [\"Finanzviertel\"],\n                \"partialMatch\": false\n            }\n        ],\n        \"semanticRecognizer\": {\n            \"name\": \"GlinerLarge\",\n            \"entityMapping\": {\n                \"name\": \"PERSON\",\n                \"first name\": \"PERSON\",\n                \"last name\": \"PERSON\",\n                \"company name\": \"ORGANISATION\",\n                \"organization name\": \"ORGANISATION\",\n                \"location address\": \"PHYSICAL_ADDRESS\",\n                \"user name\": \"USERNAME\"\n            }\n        },\n        \"sameSpanStrategy\": \"DeterministicWins\"\n    }\n}"
						},
