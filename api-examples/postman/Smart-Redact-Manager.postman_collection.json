		{
			"name": "Jobs - SI Detection",
			"item": [
				{
					"name": "Create SI Detection Job (Sync)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 202) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"jobId\", jsonData.jobId);",
									"    console.log(\"Saved jobId: \" + jsonData.jobId);",
									"    ",
									"    if (jsonData.outputFiles && jsonData.outputFiles.length > 0) {",
									"        var fdfFile = jsonData.outputFiles.find(f => f.fileCode === 'fdf');",
									"        if (fdfFile) {",
									"            pm.collectionVariables.set(\"fdfFileId\", fdfFile.fileId);",
									"            pm.collectionVariables.set(\"fdfDekToken\", fdfFile.dekToken);",
									"            console.log(\"Saved fdfFileId: \" + fdfFile.fileId);",
									"            console.log(\"Saved fdfDekToken\");",
									"        }",
									"    }",
									"",
									"    if (jsonData.result && jsonData.result.redactions) {",
									"        pm.collectionVariables.set(\"redactions\", JSON.stringify(jsonData.result.redactions));",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"pdfFileId\": \"{{pdfFileId}}\",\n    \"dekToken\": \"{{pdfDekToken}}\",\n    \"processingMode\": \"sync\",\n    \"detectionConfiguration\": {\n        \"scoreThreshold\": 0.5\n    }\n}"
						},
