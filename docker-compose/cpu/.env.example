# =============================================================================
# Smart Redact - CPU Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# Usage: cp .env.example .env && nano .env
# =============================================================================

# [REQUIRED] Smart Redact license key
PII_SERVICE_LICENSE_KEY=<your-license-key>

# [REQUIRED] File encryption key (AES-256-GCM, 32-byte Base64-encoded)
# Generate with: ../../scripts/generate-encryption-key.sh
ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# [REQUIRED] JWT signing secret for Orchestrator (minimum 32 characters)
# Generate with: openssl rand -base64 64 | tr -d '\n'
ORCHESTRATOR_JWT_SECRET=<minimum-32-character-string>

# [Optional] Docker image version tag (default: 0.99.0)
# VERSION=0.99.0

# [Optional] HITL Web UI host port and browser-facing API URLs
# HITL_WEB_PORT=3000
# HITL_ORCHESTRATOR_URL=http://localhost:9983
# HITL_MANAGER_URL=http://localhost:9982

# [Optional] OpenTelemetry - uncomment to enable
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
