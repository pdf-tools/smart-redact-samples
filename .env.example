# =============================================================================
# AI Smart Redact - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
#
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Licensing [REQUIRED]
# -----------------------------------------------------------------------------
# Your AI Smart Redact license key.
# Generate a free trial key at https://portal.pdf-tools.com/ or see
# https://www.pdf-tools.com/docs/smart-redact/licensing for production keys.
PDFTOOLS_LICENSE_KEY=<your-license-key>

# -----------------------------------------------------------------------------
# Encryption [REQUIRED]
# -----------------------------------------------------------------------------
# 32-byte Base64-encoded encryption key for file-at-rest encryption (AES-256-GCM).
# Generate one with: ./scripts/generate-encryption-key.sh
ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# -----------------------------------------------------------------------------
# Orchestrator Authentication [REQUIRED if using Orchestrator]
# -----------------------------------------------------------------------------
# JWT signing secret (minimum 32 characters).
# Generate one with: openssl rand -base64 64 | tr -d '\n'
ORCHESTRATOR_JWT_SECRET=<minimum-32-character-string>

# -----------------------------------------------------------------------------
# Image Version (optional)
# -----------------------------------------------------------------------------
# Docker image tag to use. Defaults to "latest".
# VERSION=latest

# -----------------------------------------------------------------------------
# HITL Web UI (optional)
# -----------------------------------------------------------------------------
# Host port and browser-facing Orchestrator URL for the human-in-the-loop review UI.
# HITL_WEB_PORT=3000
# HITL_ORCHESTRATOR_URL=http://localhost:9983
